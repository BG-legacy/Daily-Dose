{
  "version": 2,
  "buildCommand": "npm install && npm install --platform=linux --arch=x64 sharp && npm install -D postcss@latest postcss-import@latest tailwindcss@latest autoprefixer@latest && npm run vercel-build",
  "devCommand": "npm run dev",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "regions": ["iad1"],
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1",
    "NEXT_DISABLE_IMAGE_OPTIMIZATION": "true"
  }
} 